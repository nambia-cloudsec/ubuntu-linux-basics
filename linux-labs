sudo chgrp staff file1

# Exercise 3: Explore sticky bit
mkdir sticky-dir
chmod 1777 sticky-dir   # set sticky bit
ls -ld sticky-dir

# Exercise 4: Try deleting as different user
touch sticky-dir/testfile
# Only owner can delete due to sticky bit

# Exercise 5: Set setgid on directory
mkdir group-dir
chmod 2775 group-dir
ls -ld group-dir
