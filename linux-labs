# Phase 3: Permissions & Ownership Exercises

# Exercise 1: Create sample files
touch file1 file2 file3

# Exercise 2: Set different permissions
chmod 644 file1      # owner read/write, others read
chmod 600 file2      # owner read/write, others none
chmod 755 file3      # owner read/write/execute, others read/execute

# Exercise 3: Explore file permissions
ls -l

# Exercise 4: Change ownership (use sudo if needed)
sudo chown nambia-mangare file1
sudo chown root file2

# Exercise 5: Explore directories permissions
ls -ld /etc /var /usr /home

# Exercise 6: Try special permissions
chmod +x file3       # make executable
=====================================================
PHASE 2 LAB: FILE SYSTEM EXPLORATION
=====================================================

# Show current directory
pwd

# Explore root
ls -la /

# Inspect configuration files
ls -l /etc | head -20

# Inspect binaries
ls -l /bin | head

# Check user directories
ls -l /home

# Check logs
ls -l /var/log | head

# Check disk usage
du -sh /home/*
du -sh /var/*

# Check overall disk space
df -h

# Detailed file information
stat /etc/passwd
stat /bin/ls
