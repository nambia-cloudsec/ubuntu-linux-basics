# Python Scripting – Phase 9 & 10

# 1. Basic Output
print("Hello, World!")

# 2. Variables
name = "Lucy"
print(f"My name is {name}")

# 3. User Input
user = input("Enter your name: ")
print(f"Welcome {user}")

# 4. Conditionals
if user == "admin":
    print("You are the administrator.")
else:
    print("Standard user.")

# 5. Loops
for i in range(1, 6):
    print(f"Number {i}")

count = 1
while count <= 3:
    print(f"Count {count}")
    count += 1

# 6. Functions
def greet(person):
    print(f"Hello {person}")

greet("Lucy")

# 7. Working with Files
with open("testfile.txt", "w") as f:
    f.write("This is a test file.")

# 8. Simple Backup Simulation
import shutil
shutil.copy("testfile.txt", "testfile_backup.txt")

print("Backup completed.")
